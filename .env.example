# Runtime profile: dev (loopback + Vite proxy) | prod (0.0.0.0 + embedded UI)
ORCHESTRATOR_PROFILE=dev

# API bind address and port
ORCHESTRATOR_BIND_ADDR=127.0.0.1
ORCHESTRATOR_PORT=47821

# SQLite database directory (orchestrator.db created inside)
ORCHESTRATOR_DATA_DIR=.data

# Production only: path to built Svelte assets (index.html + assets)
ORCHESTRATOR_STATIC_DIR=web/dist

# Vite dev proxy target (web/.env.local optional)
# VITE_API_PROXY=http://127.0.0.1:47821

# Production web build: empty = same origin
# VITE_API_BASE=
